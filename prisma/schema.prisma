// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  name      String
  email     String?   @unique
  birthdate DateTime?
  password  String
  phone     String?
  avatar    String?
  bio       String?

  status Boolean @default(true)

  role Role @default(STUDENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  educator  Educator?
  student   Student?
  guardian  Guardian?

  // Relações com Disciplinas
  disciplines           Discipline[]           @relation("TeacherDisciplines")
  disciplineEnrollments DisciplineEnrollment[]
}

enum Role {
  STUDENT
  EDUCATOR
  GUARDIAN
  ADMIN
}

enum LibrasLevel {
  BASICO
  INTERMEDIARIO
  AVANCADO
  FLUENTE
}

// Identifica se o Educator é Professor ou Intérprete dentro da plataforma
enum EducatorType {
  TEACHER  
  INTERPRETER
}

//
// EDUCATOR (absorve Professor e Intérprete)

model Educator {
  id           String       @id @default(uuid())
  userId       String       @unique
  educatorType EducatorType @default(TEACHER)

  // Dados comuns
  institute String

  // Dados específicos do Professor (opcionais para Intérprete)
  department String?
  specialty  String?

  // Dados específicos do Intérprete (opcionais para Professor)
  certificate        String?
  areaAtuacao        String?
  proficienciaLibras LibrasLevel?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//
// STUDENT

model Student {
  id                    String  @id @default(uuid())
  userId                String  @unique
  institute             String?
  grauEscolar           String
  necessidadesEspeciais String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//
// GUARDIAN (Responsável)

model Guardian {
  id           String  @id @default(uuid())
  userId       String  @unique
  parentesco   String
  studentEmail String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// DISCIPLINE (Turma)
// ─────────────────────────────────────────────

enum SchoolLevel {
  ENSINO_MEDIO_1 
  ENSINO_MEDIO_2 
  ENSINO_MEDIO_3
}

enum ClassRole {
  STUDENT   
  FAMILY  
  INTERPRETER
  ASSISTANT  // (uso futuro)
}

model Discipline {
  id              String      @id @default(uuid())
  name            String
  description     String?
  colorBackground String?     // Hexadecimal: ex "#BACA57"
  classCode       String      @unique // Gerado pelo service (ex: "ABC1D2")
  schoolYear      Int?         // ex: 2026
  schoolLevel     SchoolLevel?
  isActive        Boolean     @default(true)
  teacherId       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher     User                   @relation("TeacherDisciplines", fields: [teacherId], references: [id])
  enrollments DisciplineEnrollment[]

  @@index([teacherId])
  @@index([classCode])
}

// ─────────────────────────────────────────────
// DISCIPLINE ENROLLMENT (Matrícula)
// ─────────────────────────────────────────────

model DisciplineEnrollment {
  id           String    @id @default(uuid())
  userId       String
  disciplineId String
  roleInClass  ClassRole

  createdAt DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discipline Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)

  // Um usuário só pode estar matriculado uma vez por disciplina
  @@unique([userId, disciplineId])
  @@index([disciplineId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// PARAM (Tabela genérica de parâmetros de selects)
// ─────────────────────────────────────────────

model Param {
  id       String  @id @default(uuid())
  type     String  // ex: "SCHOOL_LEVEL", "SCHOOL_YEAR", "PARENTESCO"
  label    String  // ex: "1º Ano do Ensino Médio"
  value    String  // ex: "ENSINO_MEDIO_1"
  order    Int     @default(0)
  isActive Boolean @default(true)

  @@index([type])
  @@unique([type, value])
}
